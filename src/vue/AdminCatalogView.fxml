<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-background-color: #121212; -fx-padding: 30;"
      xmlns:fx="http://javafx.com/fxml" fx:controller="controller.AdminCatalogController">

    <Label text="Gestion du Catalogue" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>

    <TabPane VBox.vgrow="ALWAYS" style="-fx-background-color: #181818;" tabClosingPolicy="UNAVAILABLE">

        <Tab text="Morceaux">
            <VBox spacing="15" style="-fx-padding: 20;">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="➕ Ajouter un morceau" onAction="#showAddMorceauForm"
                            style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>

                <TableView fx:id="morceauxTable" VBox.vgrow="ALWAYS" style="-fx-base: #282828;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colTitre" text="Titre" prefWidth="250"/>
                        <TableColumn fx:id="colGenre" text="Genre" prefWidth="150"/>
                        <TableColumn fx:id="colTemps" text="Durée (s)" prefWidth="100"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="Albums">
            <VBox spacing="15" style="-fx-padding: 20;">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="➕ Ajouter un album" onAction="#showAddAlbumForm"
                            style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>

                <TableView fx:id="albumTable" VBox.vgrow="ALWAYS" style="-fx-base: #282828;">
                    <columns>
                        <TableColumn fx:id="colAlbumId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colAlbumName" text="Nom" prefWidth="250"/>
                        <TableColumn fx:id="colAlbumDate" text="Date Création" prefWidth="150"/>
                        <TableColumn fx:id="colAlbumCreateur" text="Créateur" prefWidth="150"/>
                        <TableColumn fx:id="colAlbumActions" text="Actions" prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>

        <Tab text="Artistes / Groupes">
            <VBox spacing="15" style="-fx-padding: 20;">
                <HBox alignment="CENTER_RIGHT">
                    <Button text="➕ Ajouter Artiste/Groupe" onAction="#showAddCreateurForm"
                            style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>

                <TableView fx:id="createursTable" VBox.vgrow="ALWAYS" style="-fx-base: #282828;">
                    <columns>
                        <TableColumn fx:id="colCreateurId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colCreateurNom" text="Nom" prefWidth="250"/>
                        <TableColumn fx:id="colCreateurType" text="Type" prefWidth="150"/>
                        <TableColumn fx:id="colCreateurActions" text="Actions" prefWidth="80"/>
                    </columns>
                </TableView>
            </VBox>
        </Tab>
    </TabPane>
</VBox>