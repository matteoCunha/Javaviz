<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>

<VBox alignment="CENTER" spacing="30" style="-fx-background-color: #121212;"
      xmlns:fx="http://javafx.com/fxml" fx:controller="controller.CreatePlaylistController">

    <padding>
        <Insets top="50" left="50" right="50" bottom="50"/>
    </padding>

    <VBox alignment="CENTER" spacing="20" maxWidth="500"
          style="-fx-background-color: #181818; -fx-padding: 40; -fx-background-radius: 15;">

        <Label text="Nouvelle Playlist" style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold;"/>

        <Rectangle width="150" height="150" fill="#282828" arcWidth="10" arcHeight="10"/>

        <VBox spacing="5" maxWidth="400">
            <Label text="Nom de la playlist" style="-fx-text-fill: #b3b3b3; -fx-font-weight: bold;"/>
            <TextField fx:id="nameField" promptText="Ex: Ma musique de sport, Années 80..."
                       style="-fx-background-color: #282828; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 5; -fx-font-size: 16;"/>
            <Label fx:id="errorLabel" text="Le nom ne peut pas être vide" textFill="#d32f2f" visible="false"/>
        </VBox>

        <CheckBox fx:id="publicCheckBox" text="Rendre cette playlist publique" selected="true"
                  style="-fx-text-fill: white; -fx-cursor: hand;"/>

        <HBox spacing="15" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
            <Button text="ANNULER" onAction="#cancelCreation"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 20;"/>

            <Button text="CRÉER LA PLAYLIST" onAction="#createPlaylist"
                    style="-fx-background-color: #d32f2f; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 20;
                           -fx-cursor: hand; -fx-padding: 10 30;"/>
        </HBox>
    </VBox>
</VBox>