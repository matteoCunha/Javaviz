<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="mainContainer" stylesheets="@styles.css" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.MainController">
   <top>
      <HBox spacing="20" alignment="CENTER_LEFT" styleClass="top-bar">
         <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
         <Button text="Accueil" styleClass="button-primary" onAction="#showHome"/>
         <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="300"/>

         <Region HBox.hgrow="ALWAYS" />

         <StackPane>
            <HBox fx:id="authContainer" spacing="15" alignment="CENTER">
               <Button text="S'inscrire" style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-font-weight: bold; -fx-cursor: hand;" onAction="#showSignUp"/>
               <Button text="Se connecter" styleClass="button-primary" style="-fx-background-color: white; -fx-text-fill: black;" onAction="#showLogin"/>
            </HBox>

            <HBox fx:id="userProfileContainer" spacing="15" alignment="CENTER" visible="false">
               <Label fx:id="userLabel" text="Pseudo" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
               <Button text="Déconnexion" style="-fx-background-color: transparent; -fx-text-fill: #d32f2f; -fx-cursor: hand; -fx-border-color: #d32f2f; -fx-border-radius: 20;" onAction="#logout"/>
            </HBox>
         </StackPane>
      </HBox>
   </top>

   <left>
      <VBox fx:id="sideMenu" spacing="15" prefWidth="200" styleClass="side-bar">
         <padding><Insets top="20" left="15"/></padding>
      </VBox>
   </left>

   <center>
      <StackPane fx:id="contentArea" />
   </center>

</BorderPane>