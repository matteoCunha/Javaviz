<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane fx:id="mainContainer" stylesheets="@styles.css" xmlns:fx="http://javafx.com/fxml" fx:controller="controller.MainController">
   <top>
      <HBox spacing="20" alignment="CENTER_LEFT" styleClass="top-bar">
         <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>

         <Button text="Accueil" styleClass="button-primary" onAction="#showHome" minWidth="-Infinity"/>
         <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="300" minWidth="150"/>

         <Region HBox.hgrow="ALWAYS" />

         <HBox fx:id="visitorLimitContainer" alignment="CENTER" visible="false">
            <Label fx:id="visitorLimitLabel" text="Écoutes restantes : 5"
                   style="-fx-text-fill: #d32f2f; -fx-font-weight: bold; -fx-background-color: #2a2a2a;
                        -fx-padding: 5 15; -fx-background-radius: 15;"
                   minWidth="-Infinity"/>
         </HBox>

         <StackPane minWidth="-Infinity">
            <HBox fx:id="authContainer" spacing="15" alignment="CENTER">
               <Button text="S'inscrire" style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-font-weight: bold; -fx-cursor: hand;" onAction="#showSignUp" minWidth="-Infinity"/>
               <Button text="Se connecter" styleClass="button-primary" style="-fx-background-color: white; -fx-text-fill: black;" onAction="#showLogin" minWidth="-Infinity"/>
            </HBox>

            <HBox fx:id="userProfileContainer" spacing="15" alignment="CENTER" visible="false" minWidth="-Infinity">
               <Label fx:id="userLabel" text="Pseudo" style="-fx-text-fill: white; -fx-font-weight: bold;" minWidth="-Infinity">
                  <graphic>
                     <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                              fill="#b3b3b3" />
                  </graphic>
               </Label>
               <Button text="Déconnexion" style="-fx-background-color: transparent; -fx-text-fill: #d32f2f; -fx-cursor: hand; -fx-border-color: #d32f2f; -fx-border-radius: 20;" onAction="#logout" minWidth="-Infinity"/>
            </HBox>
         </StackPane>
      </HBox>
   </top>

   <left>
      <VBox fx:id="sideMenu" spacing="15" prefWidth="200" styleClass="side-bar">
         <padding><Insets top="20" left="15"/></padding>

         <Button fx:id="buttonAddPlay" text="➕ Créer une playlist" onAction="#showCreatePlaylist"
                 style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-font-weight: bold; -fx-cursor: hand;"/>

         <Button fx:id="btnHistorique" text="🕒 Récemment écouté" onAction="#showHistorique"
                 style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                 visible="false"/>

         <Separator fx:id="separatorAddPlay" style="-fx-background-color: #282828;" />

         <VBox fx:id="playlistsContainer" spacing="10" />
      </VBox>
   </left>

   <center>
      <StackPane fx:id="contentArea" />
   </center>

   <bottom>
      <fx:include fx:id="playerView" source="PlayerView.fxml" />
   </bottom>
</BorderPane>