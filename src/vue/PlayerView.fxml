<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.geometry.Insets?>

<BorderPane fx:controller="controller.PlayerViewController"
            style="-fx-background-color: #181818; -fx-border-color: #282828; -fx-border-width: 1 0 0 0;"
            xmlns:fx="http://javafx.com/fxml"
            prefHeight="90">

    <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>

    <left>
        <HBox spacing="15" alignment="CENTER_LEFT" prefWidth="250">
            <Rectangle fx:id="coverImage" width="56" height="56" fill="#282828" arcWidth="10" arcHeight="10"/>
            <VBox alignment="CENTER_LEFT" spacing="2">
                <Label fx:id="trackTitle" text="Titre de la musique" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <Label fx:id="artistName" text="Artiste" style="-fx-text-fill: #b3b3b3; -fx-font-size: 11;"/>
            </VBox>
        </HBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="5" maxWidth="500">
            <HBox spacing="20" alignment="CENTER">
                <Button text="⏮" style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-cursor: hand;"/>
                <Button fx:id="playPauseBtn" text="▶" onAction="#togglePlayPause"
                        style="-fx-background-color: white; -fx-text-fill: black; -fx-background-radius: 50; -fx-pref-width: 35; -fx-pref-height: 35; -fx-cursor: hand;"/>
                <Button text="⏭" style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-cursor: hand;"/>
            </HBox>

            <HBox spacing="10" alignment="CENTER" maxWidth="Infinity">
                <Label fx:id="currentTimeLabel" text="0:00" style="-fx-text-fill: #b3b3b3; -fx-font-size: 11;"/>
                <Slider fx:id="timeSlider" HBox.hgrow="ALWAYS" styleClass="player-slider"/>
                <Label fx:id="totalTimeLabel" text="3:45" style="-fx-text-fill: #b3b3b3; -fx-font-size: 11;"/>
            </HBox>
        </VBox>
    </center>

    <right>
        <HBox alignment="CENTER_RIGHT" spacing="10" prefWidth="250">
            <Label text="🔊" style="-fx-text-fill: #b3b3b3;"/>
            <Slider fx:id="volumeSlider" prefWidth="100" value="50" styleClass="player-slider"/>
        </HBox>
    </right>
</BorderPane>