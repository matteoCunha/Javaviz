<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" style="-fx-background-color: #121212; -fx-padding: 40;"
      xmlns:fx="http://javafx.com/fxml" fx:controller="controller.AddMorceauController">

    <Label text="Ajouter un nouveau morceau" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #d32f2f; -fx-font-weight: bold;" managed="false" visible="false"/>

    <GridPane hgap="15" vgap="20" alignment="CENTER" style="-fx-background-color: #181818; -fx-padding: 30; -fx-background-radius: 10;">

        <Label text="Titre :" style="-fx-text-fill: #b3b3b3; -fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="titreField" promptText="Ex: Bohemian Rhapsody" prefWidth="300" styleClass="text-field-dark" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Genre :" style="-fx-text-fill: #b3b3b3; -fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="genreField" promptText="Ex: Rock" styleClass="text-field-dark" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Durée (en secondes) :" style="-fx-text-fill: #b3b3b3; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="dureeField" promptText="Ex: 354" styleClass="text-field-dark" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Artiste :" style="-fx-text-fill: #b3b3b3; -fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <ComboBox fx:id="artisteComboBox" promptText="Sélectionner un artiste..." prefWidth="300"
                  style="-fx-background-color: #282828; -fx-text-fill: white;"
                  GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="20" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
        <Button text="Annuler" onAction="#handleCancel"
                style="-fx-background-color: transparent; -fx-text-fill: #b3b3b3; -fx-border-color: #b3b3b3; -fx-border-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;"/>

        <Button text="ENREGISTRER" onAction="#handleSave"
                style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 30; -fx-cursor: hand;"/>
    </HBox>

</VBox>