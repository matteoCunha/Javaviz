<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.shape.SVGPath?>
<ScrollPane fx:controller="controller.PlaylistDetailController"
            fitToWidth="true" hbarPolicy="NEVER"
            style="-fx-background-color: transparent; -fx-background: transparent;"
            xmlns:fx="http://javafx.com/fxml">

    <VBox spacing="30" style="-fx-background-color: #121212;">
        <padding><Insets top="30" left="30" right="30" bottom="50"/></padding>

        <HBox spacing="30" alignment="BOTTOM_LEFT">
            <Rectangle width="200" height="200" arcWidth="20" arcHeight="20" fill="#282828" />

            <VBox spacing="10">
                <Label fx:id="statusLabel" text="PLAYLIST PUBLIQUE" style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;"/>
                <Label fx:id="playlistTitle" text="Nom de la Playlist"
                       style="-fx-text-fill: white; -fx-font-size: 48; -fx-font-weight: bold;"/>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="creatorName" text="Créée par..."
                           style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Label text="•" style="-fx-text-fill: #b3b3b3;"/>
                    <Label fx:id="trackCount" text="0 titres" style="-fx-text-fill: #b3b3b3;"/>
                </HBox>
            </VBox>
        </HBox>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <Button text="▶" style="-fx-background-color: #d32f2f; -fx-text-fill: white;
                                   -fx-font-size: 24; -fx-background-radius: 50;
                                   -fx-pref-width: 60; -fx-pref-height: 60; -fx-cursor: hand;"/>
        </HBox>

        <Button fx:id="deleteButton" onAction="#handleDeletePlaylist"
                style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 5;">
            <graphic>
                <SVGPath content="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                         fill="#d32f2f" />
            </graphic>
        </Button>

        <VBox spacing="5">
            <HBox spacing="10" style="-fx-padding: 0 10 10 10; -fx-border-color: #282828; -fx-border-width: 0 0 1 0;">
                <Label text="#" prefWidth="30" style="-fx-text-fill: #b3b3b3;"/>
                <Label text="TITRE" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-text-fill: #b3b3b3;"/>
                <Label text="ACTIONS" prefWidth="80" alignment="CENTER" style="-fx-text-fill: #b3b3b3;"/>
            </HBox>

            <VBox fx:id="trackListContainer" spacing="2" style="-fx-padding: 10 0 0 0;" />
            <Region prefHeight="30" />
            <Separator style="-fx-background-color: #282828;" />
            <Region prefHeight="10" />

            <VBox spacing="15">
                <Label text="Ajouter des morceaux" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <ComboBox fx:id="trackComboBox" promptText="Sélectionner un titre à ajouter..."
                              prefWidth="300" style="-fx-background-color: #282828; -fx-base: #282828;"/>

                    <Button text="AJOUTER" onAction="#addSelectedTrack"
                            style="-fx-background-color: transparent; -fx-text-fill: white;
                               -fx-border-color: white; -fx-border-radius: 20;
                               -fx-padding: 5 15; -fx-cursor: hand; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>